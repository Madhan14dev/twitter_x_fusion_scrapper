# Twitter Scraping Pipeline - Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Twitter Authentication
# ============================================
# Path to your cookies JSON file
# Create this file at config/accounts.json
# See README for instructions on getting cookies
TWITTER_COOKIES_FILE=config/accounts.json

# ============================================
# Network Settings
# ============================================
# HTTP/HTTPS proxy (optional)
# Format: http://username:password@host:port
# Example: http://127.0.0.1:8080
TWS_PROXY=

# SSL verification (set to 'false' for corporate proxies with SSL inspection)
TWS_SSL_VERIFY=true

# ============================================
# Rate Limiting
# ============================================
# Requests per minute (default: 60)
# TWS_RATE_LIMIT_MINUTE=60

# Requests per hour (default: 500)
# TWS_RATE_LIMIT_HOUR=500

# ============================================
# Logging
# ============================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# Output Settings
# ============================================
# Output directory (default: output)
# TWS_OUTPUT_DIR=output

# Database path (default: pipeline.db)
# TWS_DB_PATH=pipeline.db

# ============================================
# Engine Settings
# ============================================
# Circuit breaker threshold (default: 5)
# TWS_CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker timeout in seconds (default: 300)
# TWS_CIRCUIT_BREAKER_TIMEOUT=300